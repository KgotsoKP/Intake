@using Intake.Components.UI

<section class="px-16 w-full">
    <div class="flex justify-center items-center gap-4 py-4 ">
        <img src="/e4-logo-black.svg" alt="e4-logo"/>
        <p class="text-5xl py-2">/</p>
        <h2 class=" text-3xl font-medium py-2">Inatke</h2>
    </div>

    <div class="flex gap-3 py-4 px-16 w-full">
        <div class="relative flex-1">
            <input
                type="text"
                class="w-full px-2 py-2.5 pr-8 rounded-lg bg-white text-sm text-gray-500 placeholder-gray-400 border-none outline-none focus:ring-2 focus:ring-gray-200"
                placeholder="Search User By Name or Surname or Cellnumber"
                @bind="SearchText"
                @bind:event="oninput"
                @bind:after="OnTextChanged"/>

            @if (!string.IsNullOrWhiteSpace(SearchText))
            {
                <button
                    type="button"
                    class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                    @onclick="ClearSearch">
                    &times;
                </button>
            }
        </div>

        @if (string.IsNullOrWhiteSpace(SearchText))
        {
            <button
                class="bg-black text-white text-sm font-medium px-4 py-2.5 !rounded-lg hover:bg-gray-800 transition-colors whitespace-nowrap"
                @onclick="Open">
                Add
            </button>
        }
        else
        {
            <button
                class="bg-amber-700 text-white text-sm font-medium px-4 py-2.5 !rounded-lg hover:bg-gray-800 transition-colors whitespace-nowrap"
                @onclick="SearchUsers">
                Search
            </button>
        }
    </div>
</section>


@code {
    private string SearchText { get; set; } = string.Empty;

    [Parameter] public EventCallback OpenAddUserDialog { get; set; }
    [Parameter] public EventCallback<string> OnSearchClicked { get; set; }
    [Parameter] public EventCallback OnSearchCleared { get; set; }

    private async Task Open()
    {
        await OpenAddUserDialog.InvokeAsync();
    }

    private async Task SearchUsers()
    {
        await OnSearchClicked.InvokeAsync(SearchText);
    }

    private async Task OnTextChanged()
    {
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            await OnSearchCleared.InvokeAsync();
        }
    }

    private async Task ClearSearch()
    {
        SearchText = string.Empty;
        await OnSearchCleared.InvokeAsync();
    }

}
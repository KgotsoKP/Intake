@using Intake.Models
@using Intake.Services
@inject IUserService UserService
@using Blazor.Sonner.Services
@inject ToastService Toast

@if (IsVisible)
{
    <EditForm Model="Model" OnValidSubmit="Submit" FormName="user-edit-form">
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 p-4">
                <!--Header -->
                <div class="flex justify-between items-center w-full my-2">
                    <h5 class="text-sm font-semibold text-gray-900">@(UserId > 0 ? "Edit User" : "Add User")</h5>
                </div>

                <!--Body -->
                <div class="space-y-4">
                    <div class="flex flex-col gap-1">
                        <label class="text-sm font-medium text-gray-700">Name<span class="text-red-500">*</span></label>
                        <InputText
                            @bind-Value="Model!.Name"
                            placeholder="Kgotso"
                            class="w-full px-3 py-2 rounded-md bg-white text-sm border border-gray-200 focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-colors"
                        />
                        <ValidationMessage For="() => Model!.Name" class="text-xs !text-red-500"/>
                    </div>

                    <div class="flex flex-col gap-1">
                        <label class="text-sm font-medium text-gray-700">Surname<span
                                class="text-red-500">*</span></label>
                        <InputText
                            @bind-Value="Model!.Surname"
                            placeholder="Phiri"
                            class="w-full px-3 py-2 rounded-md bg-white text-sm border border-gray-200 focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-colors"
                        />
                        <ValidationMessage For="() => Model!.Surname" class="text-xs !text-red-500"/>
                    </div>

                    <div class="flex flex-col gap-1">
                        <label class="text-sm font-medium text-gray-700">Cellphone Number<span
                                                                                             class="text-red-500">*</span></label>

                        <div class="relative w-full">
                            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                <img src="Flag_of_South_Africa.svg.png" alt="South Africa flag"
                                     class="h-4 w-4 rounded-sm"/>
                            </div>

                            <InputText
                                @bind-Value="Model!.CellphoneNumber"
                                placeholder="072 343 5423"
                                class="w-full pl-10 pr-3 py-2 rounded-md bg-white text-sm border border-gray-200 focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-colors"
                            />
                        </div>

                        <ValidationMessage For="() => Model!.CellphoneNumber" class="text-xs !text-red-500"/>
                    </div>
                </div>

                <!--Footer -->
                <div class="flex justify-end w-full pt-4 gap-2">
                    <button type="button"
                            class="bg-white border-2 text-gray-400 text-sm font-medium px-4 py-2 !rounded-lg hover:bg-gray-800 transition-colors whitespace-nowrap"
                            @onclick="Close">Cancel
                    </button>
                    <button
                        class="bg-black text-white text-sm font-medium px-4 py-2 !rounded-lg hover:bg-gray-800 transition-colors whitespace-nowrap"
                        type="submit">Save
                    </button>
                </div>

                <DataAnnotationsValidator/>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback RefetchUsers { get; set; }
    [Parameter] public int? UserId { get; set; }

    [SupplyParameterFromForm] private User? Model { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (UserId == null)
        {
            Model = new User();
        }
        else
        {
            var result = await UserService.GetUserById((int)UserId);

            if (result.IsSuccess)
            {
                Model = result.Value;
            }
            else
            {
                Toast.Error("Failed to fetch user", opts => { opts.Description = result.Error.Description; });
            }
        }
    }

    private async Task Close()
    {
        Model = new();
        await OnClose.InvokeAsync();
    }

    private async Task Submit()
    {
        if (UserId != null)
        {
            await UserService.UpdateUser(Model);
            Toast.Success("User updated successfully", opts => { opts.Description = "Changes have been saved."; });
        }
        else
        {
            var result = await UserService.AddUser(Model);

            if (result.IsSuccess)
            {
                Toast.Success("User added successfully", opts => { opts.Description = "The new user has been created."; });
            }
            else
            {
                Toast.Error("Failed to add user", opts => { opts.Description = result.Error.Description; });
            }
        }

        await Close();
        await RefetchUsers.InvokeAsync();
    }

}